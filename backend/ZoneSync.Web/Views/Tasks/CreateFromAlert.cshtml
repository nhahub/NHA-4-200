@model ZoneSync.Web.Models.TaskFromAlertViewModel
@{ ViewData["Title"] = "Create Task from Alert"; }

<h2>Create Task from Alert #@Model.AlertId</h2>

<form asp-action="CreateFromAlert" method="post">
    <input type="hidden" asp-for="AlertId" />
    <input type="hidden" asp-for="ZoneId" />

    <div class="mb-3">
        <label>Task Name</label>
        <input asp-for="TaskName" class="form-control" />
        <span asp-validation-for="TaskName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label>Description</label>
        <textarea asp-for="TaskDesc" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label>Due Date</label>
        <input asp-for="DueDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Verification Hours (optional - default from requirement)</label>
        <input asp-for="ActualVerificationAfterHours" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Created By (User Id)</label>
        <input asp-for="CreatedByUserId" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Create Task</button>
</form>