@model ZoneSync.Web.ViewModels.FarmZone.CreateZoneViewModel

@{
    ViewData["Title"] = "Create Zone";
    var farmMembers = ViewBag.FarmMembers as List<(int UserId, string FullName, ZoneSync.Core.Enums.FarmRoleType RoleType)>;
}

<h1>Create Zone</h1>

<form asp-action="Create" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="FarmId" />

    <div class="col-md-6">
        <label asp-for="ZoneName" class="form-label"></label>
        <input asp-for="ZoneName" class="form-control" />
        <span asp-validation-for="ZoneName" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="ZoneArea" class="form-label"></label>
        <input asp-for="ZoneArea" class="form-control" />
        <span asp-validation-for="ZoneArea" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="SupervisorUserId" class="form-label"></label>
        <select asp-for="SupervisorUserId" class="form-select">
            <option value="">-- None --</option>
            @if (farmMembers is not null)
            {
                @foreach (var member in farmMembers)
                {
                    <option value="@member.UserId">@member.FullName (@member.RoleType)</option>
                }
            }
        </select>
        <span asp-validation-for="SupervisorUserId" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="AssignedUserIds" class="form-label"></label>
        @if (farmMembers is not null)
        {
            @foreach (var member in farmMembers)
            {
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" name="AssignedUserIds" value="@member.UserId" />
                    <label class="form-check-label">@member.FullName (@member.RoleType)</label>
                </div>
            }
        }
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
