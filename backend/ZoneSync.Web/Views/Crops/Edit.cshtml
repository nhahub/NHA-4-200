@model ZoneSync.Core.Entities.CropModule.Crop

@{
    ViewData["Title"] = "Edit Crop";
}

<h1>Edit Crop</h1>
<form asp-action="Edit" asp-route-id="@Model.CropId" method="post" class="row g-3">
    <input type="hidden" asp-for="CropId" />
    <partial name="_CropForm" model="Model" />
    <div class="col-12">
        <button type="submit" class="btn btn-success">Save</button>
        <a asp-action="Details" asp-route-id="@Model.CropId" class="btn btn-secondary">Cancel</a>
    </div>
</form>
