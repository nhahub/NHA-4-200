@model IEnumerable<ZoneSync.Core.Entities.Sensors.MeasurementType>

@{
    ViewData["Title"] = "Measurement Types";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Measurement Types</h1>
    <a asp-action="Create" class="btn btn-success">New Measurement Type</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Unit</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Unit</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
