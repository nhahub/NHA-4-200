@model ZoneSync.Core.Entities.Sensors.MeasurementType

@{
    ViewData["Title"] = "Edit Measurement Type";
}

<h1>Edit Measurement Type</h1>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
    <partial name="_MeasurementTypeForm" model="Model" />
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
