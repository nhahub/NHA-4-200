@model ZoneDashboardViewModel
@{
    ViewData["Title"] = $"{Model.ZoneName} - Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Model.ZoneName Dashboard</h1>
    <div>
        <a asp-controller="Dashboard" asp-action="FarmDashboard" asp-route-farmId="@Model.FarmId" class="btn btn-outline-primary">Farm Dashboard</a>
        <a asp-controller="Zones" asp-action="Details" asp-route-id="@Model.ZoneId" class="btn btn-outline-secondary">Zone Details</a>
    </div>
</div>

<div class="row mb-2">
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">@Model.ZoneArea.ToString("N2")</h5>
                <p class="card-text">Area</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.ZoneStatus == "Planted" ? "bg-success" : Model.ZoneStatus == "Available" ? "bg-primary" : "bg-secondary") mb-3">
            <div class="card-body">
                <h5 class="card-title">@Model.ZoneStatus</h5>
                <p class="card-text">Status</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">@Model.OpenAlerts.Count</h5>
                <p class="card-text">Open Alerts</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">@Model.OpenTasks.Count</h5>
                <p class="card-text">Open Tasks</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Zone Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Farm</dt>
                    <dd class="col-sm-8">@Model.FarmName</dd>
                    <dt class="col-sm-4">Supervisor</dt>
                    <dd class="col-sm-8">@(Model.SupervisorName ?? "Not assigned")</dd>
                    <dt class="col-sm-4">Assigned Users</dt>
                    <dd class="col-sm-8">@Model.AssignedUsersCount</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Current Crop Plan</h5>
            </div>
            <div class="card-body">
                @if (Model.CurrentCropPlan != null)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Crop</dt>
                        <dd class="col-sm-8">@Model.CurrentCropPlan.CropName</dd>
                        <dt class="col-sm-4">Planted</dt>
                        <dd class="col-sm-8">@Model.CurrentCropPlan.PlantingDate.ToString("d")</dd>
                        <dt class="col-sm-4">Harvest</dt>
                        <dd class="col-sm-8">
                            @Model.CurrentCropPlan.PredictedHarvestTime.ToString("d")
                            @if (Model.CurrentCropPlan.ActualHarvestTime.HasValue)
                            {
                                <span class="text-muted">(Actual: @Model.CurrentCropPlan.ActualHarvestTime.Value.ToString("d"))</span>
                            }
                        </dd>
                        <dt class="col-sm-4">Stage</dt>
                        <dd class="col-sm-8">
                            @Model.CurrentCropPlan.CurrentStageName
                            <span class="badge bg-info">@Model.CurrentCropPlan.CurrentStageStatus</span>
                            <span class="text-muted">(@Model.CurrentCropPlan.CurrentStageOrder of @Model.CurrentCropPlan.TotalStages)</span>
                        </dd>
                        @if (Model.CurrentCropPlan.StagePredictedEndDate.HasValue)
                        {
                            <dt class="col-sm-4">Stage Ends</dt>
                            <dd class="col-sm-8">@Model.CurrentCropPlan.StagePredictedEndDate.Value.ToString("d")</dd>
                        }
                    </dl>
                }
                else
                {
                    <p class="text-muted mb-0">No active crop plan</p>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.StageReadings.Any())
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Stage Requirements & Readings</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Requirement</th>
                                <th>Min</th>
                                <th>Max</th>
                                <th>Unit</th>
                                <th>Latest Reading</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.StageReadings)
                            {
                                <tr>
                                    <td>@item.RequirementName</td>
                                    <td>@item.MinValue.ToString("N2")</td>
                                    <td>@item.MaxValue.ToString("N2")</td>
                                    <td>@item.Unit</td>
                                    <td>@(item.LatestReadingValue?.ToString("N2") ?? "No data")</td>
                                    <td>
                                        @if (item.IsSatisfied.HasValue)
                                        {
                                            if (item.IsSatisfied.Value)
                                            {
                                                <span class="badge bg-success">Satisfied</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Not Satisfied</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Checked</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Sensors in Zone</h5>
            </div>
            <div class="card-body">
                @if (Model.SensorStatuses.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Serial</th>
                                <th>Model</th>
                                <th>Status</th>
                                <th>Last Reading</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sensor in Model.SensorStatuses)
                            {
                                <tr>
                                    <td>@sensor.SerialNumber</td>
                                    <td>@sensor.ModelName</td>
                                    <td>
                                        <span class="badge @(sensor.Status == "Available" ? "bg-secondary" : sensor.Status == "Configured" ? "bg-success" : sensor.Status == "Maintenance" ? "bg-warning" : "bg-danger")">
                                            @sensor.Status
                                        </span>
                                    </td>
                                    <td>@(sensor.LastReadingDate?.ToString("g") ?? "No data")</td>
                                    <td>@(sensor.LastReadingValue?.ToString("N2") ?? "-") @sensor.LastReadingType</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">No sensors configured in this zone</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>Open Alerts</h5>
                <a asp-controller="Alerts" asp-action="Create" asp-route-zoneId="@Model.ZoneId" class="btn btn-sm btn-warning">Create Alert</a>
            </div>
            <div class="card-body">
                @if (Model.OpenAlerts.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Severity</th>
                                <th>Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alert in Model.OpenAlerts)
                            {
                                <tr>
                                    <td>@alert.AlertType</td>
                                    <td>
                                        <span class="badge @(alert.AlertSeverity == "Critical" ? "bg-danger" : alert.AlertSeverity == "High" ? "bg-warning" : alert.AlertSeverity == "Medium" ? "bg-info" : "bg-secondary")">
                                            @alert.AlertSeverity
                                        </span>
                                    </td>
                                    <td>@alert.FiringDate.ToString("g")</td>
                                    <td>
                                        <a asp-controller="Alerts" asp-action="Details" asp-route-id="@alert.AlertId" class="btn btn-sm btn-outline-info">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">No open alerts</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>Open Tasks</h5>
                <a asp-controller="Tasks" asp-action="CreateManual" asp-route-zoneId="@Model.ZoneId" class="btn btn-sm btn-primary">Create Task</a>
            </div>
            <div class="card-body">
                @if (Model.OpenTasks.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Priority</th>
                                <th>Due</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.OpenTasks)
                            {
                                <tr>
                                    <td>@task.TaskName</td>
                                    <td>
                                        <span class="badge @(task.TaskPriority == "High" ? "bg-danger" : task.TaskPriority == "Medium" ? "bg-warning" : "bg-info")">
                                            @task.TaskPriority
                                        </span>
                                    </td>
                                    <td>@task.DueDate.ToString("d")</td>
                                    <td>
                                        <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-info">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">No open tasks</p>
                }
            </div>
        </div>
    </div>
</div>
