@model ZoneSync.Web.ViewModels.Account.AcceptInvitationViewModel

@{
    ViewData["Title"] = "Accept Invitation";
}

<h1>Accept Invitation</h1>

<form asp-action="AcceptInvitation" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-4">
        <label asp-for="Token" class="form-label"></label>
        <input asp-for="Token" class="form-control" />
        <span asp-validation-for="Token" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="VerificationCode" class="form-label"></label>
        <input asp-for="VerificationCode" class="form-control" />
        <span asp-validation-for="VerificationCode" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="ReceivedByUserId" class="form-label"></label>
        <input asp-for="ReceivedByUserId" class="form-control" />
        <span asp-validation-for="ReceivedByUserId" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Accept</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
