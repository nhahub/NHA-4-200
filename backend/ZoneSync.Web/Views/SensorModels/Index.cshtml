@model IEnumerable<ZoneSync.Core.Entities.Sensors.SensorModel>

@{
    ViewData["Title"] = "Sensor Models";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Sensor Models</h1>
    <a asp-action="Create" class="btn btn-success">New Sensor Model</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Model</th>
            <th>Type</th>
            <th>Output</th>
            <th>Measurement Types</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ModelName</td>
            <td>@item.Type</td>
            <td>@item.OutputType</td>
            <td>@string.Join(", ", item.SensorModelMeasurementTypes.Select(link => link.MeasurementType?.Name))</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
