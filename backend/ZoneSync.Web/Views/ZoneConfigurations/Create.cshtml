@model ZoneSync.Web.ViewModels.Sensors.ZoneConfigurationFormViewModel

@{
    ViewData["Title"] = "Configure Sensor";
}

<h1>Configure Sensor In Zone</h1>
<form asp-action="Create" method="post" class="row g-3">
    <div class="col-md-6">
        <label asp-for="ZoneId" class="form-label"></label>
        <select asp-for="ZoneId" asp-items="Model.ZonesList" class="form-select">
            <option value="">-- Select a zone --</option>
        </select>
        <span asp-validation-for="ZoneId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="SensorInstanceId" class="form-label"></label>
        <select asp-for="SensorInstanceId" asp-items="Model.SensorInstancesList" class="form-select">
            <option value="">-- Select a sensor --</option>
        </select>
        <span asp-validation-for="SensorInstanceId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ConfiguredByUserId" class="form-label"></label>
        <select asp-for="ConfiguredByUserId" asp-items="Model.UsersList" class="form-select">
            <option value="">-- Select a user --</option>
        </select>
        <span asp-validation-for="ConfiguredByUserId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ConfiguredAt" class="form-label"></label>
        <input asp-for="ConfiguredAt" class="form-control" />
        <span asp-validation-for="ConfiguredAt" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-success">Configure</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
