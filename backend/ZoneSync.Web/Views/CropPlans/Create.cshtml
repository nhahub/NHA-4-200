@{
    Layout = "_Layout";
}
@model ZoneSync.Web.ViewModels.CreateCropPlanViewModel

@{
    ViewData["Title"] = "New Crop Plan";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h4 class="fw-bold text-dark"><i class="bi bi-calendar-plus text-success me-2"></i> New Crop Plan</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        
                        <div class="mb-4">
                            <label asp-for="CropId" class="form-label text-muted fw-bold small text-uppercase">Crop Type</label>
                            <select asp-for="CropId" asp-items="Model.CropsList" class="form-select form-select-lg bg-light border-0">
                                <option value="">-- Select a Crop --</option>
                            </select>
                            <span asp-validation-for="CropId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ZoneId" class="form-label text-muted fw-bold small text-uppercase">Assign to Zone</label>
                            <select asp-for="ZoneId" asp-items="Model.ZonesList" class="form-select form-select-lg bg-light border-0">
                                <option value="">-- Select a Zone --</option>
                            </select>
                            <span asp-validation-for="ZoneId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PlantingDate" class="form-label text-muted fw-bold small text-uppercase">Planting Date</label>
                            <input asp-for="PlantingDate" class="form-control form-control-lg bg-light border-0" />
                            <span asp-validation-for="PlantingDate" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill">
                                Confirm plan <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}