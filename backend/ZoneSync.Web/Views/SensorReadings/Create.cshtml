@model ZoneSync.Web.ViewModels.Sensors.SensorReadingFormViewModel

@{
    ViewData["Title"] = "Add Sensor Reading";
}

<h1>Add Sensor Reading</h1>
<form asp-action="Create" method="post" class="row g-3">
    <div class="col-md-6">
        <label asp-for="SensorInstanceId" class="form-label"></label>
        <select asp-for="SensorInstanceId" asp-items="Model.SensorInstancesList" class="form-select">
            <option value="">-- Select a sensor --</option>
        </select>
        <span asp-validation-for="SensorInstanceId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="MeasurementTypeId" class="form-label"></label>
        <select asp-for="MeasurementTypeId" asp-items="Model.MeasurementTypesList" class="form-select">
            <option value="">-- Select a measurement type --</option>
        </select>
        <span asp-validation-for="MeasurementTypeId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ReadingValue" class="form-label"></label>
        <input asp-for="ReadingValue" class="form-control" />
        <span asp-validation-for="ReadingValue" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ReadingDate" class="form-label"></label>
        <input asp-for="ReadingDate" class="form-control" />
        <span asp-validation-for="ReadingDate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ReadingTime" class="form-label"></label>
        <input asp-for="ReadingTime" class="form-control" />
        <span asp-validation-for="ReadingTime" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-success">Add Reading</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
