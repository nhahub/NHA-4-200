@model IEnumerable<ZoneSync.Core.Entities.Sensors.SensorInstance>

@{
    ViewData["Title"] = "Sensor Instances";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Sensor Instances</h1>
    <a asp-action="Create" class="btn btn-success">New Sensor Instance</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Serial Number</th>
            <th>Model</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.SerialNumber</td>
            <td>@item.SensorModel?.ModelName</td>
            <td>@item.Status</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
