@model ZoneSync.Web.ViewModels.Sensors.SensorInstanceFormViewModel

@{
    ViewData["Title"] = "Create Sensor Instance";
}

<h1>Create Sensor Instance</h1>
<form asp-action="Create" method="post" class="row g-3">
    <partial name="_SensorInstanceForm" model="Model" />
    <div class="col-12">
        <button type="submit" class="btn btn-success">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
