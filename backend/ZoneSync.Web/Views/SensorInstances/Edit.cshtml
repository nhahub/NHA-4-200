@model ZoneSync.Web.ViewModels.Sensors.SensorInstanceFormViewModel

@{
    ViewData["Title"] = "Edit Sensor Instance";
}

<h1>Edit Sensor Instance</h1>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
    <partial name="_SensorInstanceForm" model="Model" />
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
